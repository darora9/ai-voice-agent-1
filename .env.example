# Groq (free tier — llama-3.3-70b with function calling)
GROQ_API_KEY=gsk_your-groq-api-key-here      # console.groq.com → API Keys
GROQ_MODEL=llama-3.3-70b-versatile

# Sarvam AI (Indian STT + TTS — free tier)
SARVAM_API_KEY=your-sarvam-api-key-here      # dashboard.sarvam.ai → API Keys
SARVAM_LANGUAGE_CODE=hi-IN                   # hi-IN for Hindi, en-IN for English
SARVAM_TTS_SPEAKER=ananya                    # Indian female voice (bulbul:v3)

# Vobiz (vobiz.ai) - Indian number provider built for AI voice agents
VOBIZ_API_KEY=your-vobiz-api-key              # Console → API Keys
VOBIZ_SIP_DOMAIN=xxxxxxxx.sip.vobiz.ai        # Console → SIP Trunk → your unique domain
VOBIZ_SIP_USERNAME=your-sip-username           # Console → SIP Trunk → Authentication
VOBIZ_SIP_PASSWORD=your-sip-password           # Console → SIP Trunk → Authentication
VOBIZ_PHONE_NUMBER=+91XXXXXXXXXX               # Console → Phone Numbers → your DID

# Google Calendar
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/google-service-account.json
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Clinic Info
DOCTOR_NAME=Dr. Sharma
CLINIC_NAME=Sharma Clinic
CLINIC_HOURS=9 AM to 6 PM, Monday to Saturday
APPOINTMENT_DURATION_MINS=30

# Server
PORT=8000
USE_WSS=true
